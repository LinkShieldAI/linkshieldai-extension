{
  "manifest_version": 3,
  "name": "LinkShield",
  "version": "1.1.0",
  "description": "Real-time malicious link protection powered by AI. Protect yourself from phishing, malware, and dangerous websites.",
  "author": "LinkShield Team",
  
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "webNavigation",
    "notifications"
  ],
  
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/lsa16.png",
      "48": "images/lsa48.png",
      "128": "images/lsa128.png"
    },
    "default_title": "LinkShield - Click to manage settings"
  },
  
  "icons": {
    "16": "images/lsa16.png",
    "48": "images/lsa48.png",
    "128": "images/lsa128.png"
  },
  
  "options_page": "options.html",
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["warning.html", "images/*"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "minimum_chrome_version": "88"
}
